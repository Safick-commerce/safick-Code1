# Supabase (Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Express API + Socket.IO — REQUIRED for chat (Message seller).
# Physical phones CANNOT use localhost — use your PC's Wi‑Fi IP:
#   Windows: ipconfig → IPv4 Address (e.g. 192.168.1.5)
#   EXPO_PUBLIC_API_URL=http://192.168.1.5:4000
# Restart Expo after changing (.env is read at bundle time).
EXPO_PUBLIC_API_URL=