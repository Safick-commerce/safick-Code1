{
  "expo": {
    "name": "safick",
    "slug": "safick",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/safick-prlogo.png",
    "scheme": "safick",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Safick uses the camera for live selling.",
        "NSMicrophoneUsageDescription": "Safick uses the microphone for live selling.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bitcode": false,
      "bundleIdentifier": "com.safick.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/safick-prlogo.png"
      },
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.WAKE_LOCK",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "package": "com.safick.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/safick-prlogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/safick-prlogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos for your profile picture."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Safick to use your camera for live selling.",
          "microphonePermission": "Allow Safick to use your microphone for live selling.",
          "recordAudioAndroid": true
        }
      ],
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "02115315-40a2-4b80-b857-8195fd160282"
      }
    }
  }
}
