# ── Backend environment (TEMPLATE ONLY) ───────────────────────────────────────
#
# Copy this file to ".env" and put real URLs and secrets there only.
# This file stays in git with empty placeholders — never paste production secrets here.
#
# ── Database (PostgreSQL / Supabase) ─────────────────────────────────────────
#
# DATABASE_URL — used by src/config/database.ts (PrismaPg at runtime).
# Must point at the SAME Supabase project as DIRECT_URL (where you ran schema SQL).
# Do NOT use Prisma Postgres (db.prisma.io) here unless you intentionally migrated all tables there.
# Prefer the Supabase **Transaction pooler** string (host …pooler.supabase.com:6543).
# The dashboard shows user as postgres.<YOUR_PROJECT_REF> — use that exactly.
# Include query params Supabase suggests, e.g. ?pgbouncer=true and sslmode.
#
# DATABASE_URL="postgresql://postgres.<YOUR_PROJECT_REF>:YOUR_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL — Prisma CLI (migrate, db pull, introspect).
# Prefer Direct: db.<YOUR_PROJECT_REF>.supabase.co:5432 (user postgres).
# If Prisma errors with P1001 ("can't reach database"), your network may block IPv6 — use
# Session pooler instead (Dashboard URI → Session mode): *.pooler.supabase.com:5432, user postgres.<ref>.
#
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.<YOUR_PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"
# Alternative if P1001 on Direct (IPv6): Session pooler — copy from Dashboard (5432, user postgres.<ref>)
# DIRECT_URL="postgresql://postgres.<YOUR_PROJECT_REF>:YOUR_PASSWORD@aws-0-....pooler.supabase.com:5432/postgres"
#
# If you only run local Docker Postgres, DATABASE_URL alone is enough; omit DIRECT_URL.

DATABASE_URL=
DIRECT_URL=

# ── Supabase Auth (verify mobile session tokens on protected routes) ───────────
# Recommended: same project URL + anon key as frontend/.env (EXPO_PUBLIC_*).
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_ANON_KEY=eyJ...   (Project Settings → API → anon public)
#
# Optional fallback: legacy JWT Secret (HS256) if you skip URL + anon key above.
# SUPABASE_JWT_SECRET=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ── Server ───────────────────────────────────────────────────────────────────
# PORT=4000
# Comma-separated origins for Express + Socket.IO (Expo web + dev server).
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# ── LiveKit Cloud (Phase 1 live — mint tokens server-side only) ─────────────
# LIVEKIT_URL=wss://YOUR_PROJECT.livekit.cloud
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# See frontend/docs/PHASE1_LIVE.md

LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Maviance Smobilpay for Service Providers (S3P) — payments + escrow payouts ──
# Risk note: frontend/docs/launch-readiness/maviance-escrow-risk-note.md
# Leave blank until merchant onboarding is complete; the backend boots without these,
# but the checkout endpoint returns 503 ("Payments not configured").
#
# MAVIANCE_S3P_BASE_URL=https://s3p.smobilpay.staging.maviance.info/v2
# MAVIANCE_S3P_API_USER=
# MAVIANCE_S3P_API_PASSWORD=
# MAVIANCE_S3P_PUBLIC_KEY=
# MAVIANCE_S3P_WEBHOOK_SECRET=
#
# Per-telco service IDs (Maviance gives one per service per merchant).
# Collect = buyer pays SAFICK. Cashin = SAFICK pays seller.
# MAVIANCE_SERVICE_ID_MTN_COLLECT=
# MAVIANCE_SERVICE_ID_ORANGE_COLLECT=
# MAVIANCE_SERVICE_ID_EXPRESS_UNION_COLLECT=
# MAVIANCE_SERVICE_ID_CARD_COLLECT=
# MAVIANCE_SERVICE_ID_MTN_CASHIN=
# MAVIANCE_SERVICE_ID_ORANGE_CASHIN=

# Leave the Maviance vars unset (not blank string) until you have credentials —
# z.coerce.number() will reject "" but accept unset for the optional ones.
# Uncomment with real values once Maviance onboarding lands.

# Number of days an order sits in `delivered` before auto-release fires and the
# seller is paid out. 7 is the launch default; adjust if a market test
# justifies a shorter window.
# ESCROW_AUTO_RELEASE_DAYS=7

#npm run dev              # run API
#npm run db:generate      # after schema edits
#npx prisma db pull       # after Supabase SQL changes

# Socket.IO: npm install socket.io (backend), socket.io-client (frontend) — no vendor signup.
#ADMIN_API_KEY=your-long-random-secret-here

# Prisma Studio: http://localhost:51212/

# npm run db:studio        # run Prisma Studio

#Hash-based Message Authentication Code using SHA-256: npm install @types/bcryptjs

# ESCROW_AUTO_RELEASE_DAYS=7 # Number of days an order sits in `delivered` before auto-release fires and the seller is paid out. 7 is the launch default; adjust if a market test justifies a shorter window.


#  The signature is the security gate that ensures only real Maviance payment results can #
# flip a checkout to paid and release escrow steps. That’s why it’s tested as a critical path.
# MAVIANCE_S3P_WEBHOOK_SECRET=